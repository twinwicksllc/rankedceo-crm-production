# =============================================================================
# RankedCEO CRM + WaaS — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# CRM: Supabase (existing CRM project)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_crm_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_crm_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_crm_supabase_service_role_key

# -----------------------------------------------------------------------------
# WaaS: Supabase (NEW standalone WaaS project — separate from CRM)
# Create a new Supabase project at https://supabase.com/dashboard
# Run supabase/migrations/waas/001_waas_tenants.sql first
# Run supabase/migrations/waas/002_waas_audits.sql second
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WAAS_SUPABASE_URL=your_waas_supabase_project_url
NEXT_PUBLIC_WAAS_SUPABASE_ANON_KEY=your_waas_supabase_anon_key
WAAS_SUPABASE_SERVICE_ROLE_KEY=your_waas_supabase_service_role_key

# -----------------------------------------------------------------------------
# Stripe (billing)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# SendGrid (email campaigns + notifications)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@rankedceo.com

# -----------------------------------------------------------------------------
# AI: Gemini Pro (lead scoring, AI features)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# -----------------------------------------------------------------------------
# AI: Perplexity (web research / competitor analysis)
# -----------------------------------------------------------------------------
PERPLEXITY_API_KEY=your_perplexity_api_key

# -----------------------------------------------------------------------------
# SEO APIs (for WaaS Audit Tool — Phase 2)
# Choose ONE primary provider (both can be configured as fallback)
# -----------------------------------------------------------------------------

# Option A: Serper.dev — Google Search API (recommended for MVP)
# Get key at: https://serper.dev
# Pricing: ~$1 per 1,000 searches
SERPER_API_KEY=your_serper_api_key

# Option B: DataForSEO — Full SEO data suite
# Get key at: https://dataforseo.com
# More comprehensive but higher cost
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# Primary SEO provider to use: 'serper' | 'dataforseo' | 'mock'
# Use 'mock' for local development (no API calls, returns dummy data)
WAAS_SEO_PROVIDER=mock

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL_PROD=https://crm.rankedceo.com
NODE_ENV=development

# WaaS base domain (used for subdomain tenant routing)
# e.g. client-a.rankedceo.com — subdomain = 'client-a', base = 'rankedceo.com'
NEXT_PUBLIC_WAAS_BASE_DOMAIN=rankedceo.com

# -----------------------------------------------------------------------------
# reCAPTCHA (public audit form + lead forms)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# -----------------------------------------------------------------------------
# Monitoring (optional — set up in production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com